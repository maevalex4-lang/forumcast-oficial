{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public and private user information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatar": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "away", "offline"] },
        "theme": { "type": "object" },
        "publicKey": { "type": "string" },
        "twoFactorEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "createdAt", "updatedAt"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "Metadata for a private or group conversation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["private", "group"] },
        "members": { "type": "object" },
        "lastMessage": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "members", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single communication event within a chat.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image", "video", "audio", "file", "location", "nudge"] },
        "metadata": { "type": "object" },
        "isEncrypted": { "type": "boolean" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "chatId", "senderId", "content", "type", "createdAt"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Relationship between two users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "contactId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "blocked"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "contactId", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and settings."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat session metadata."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a specific chat."
    },
    "/users/{userId}/contacts/{contactId}": {
      "schema": "Contact",
      "description": "User contact list."
    }
  }
}
